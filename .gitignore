# In your VS Code terminal
cat > .gitignore << 'EOF'
# Raw data files — too large or not yours to redistribute
raw_datasets/*.zip
raw_datasets/BACI_*
raw_datasets/international_trade_*
raw_datasets/semiconductor_companies_*

# Processed outputs — live in Databricks/Snowflake not GitHub
*.parquet
*.feather
/output/

# Secrets — never commit these
.env
.env.local
*.key
credentials.json
snowflake_config.py

# Pythonpip
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# OS noise
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
EOFsql/databricks/upload_baci.py
